# 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# DeepSeek API配置
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 备选LLM配置（可选）
# BACKUP_API_KEY=your-backup-api-key
# BACKUP_BASE_URL=https://api.openai.com/v1
# BACKUP_MODEL=gpt-4

# 数据库配置（可选）
# AGENT_DB_PATH=data/sample.db

# 向量库配置（可选）
# AGENT_CHROMA_DIR=data/chroma_db

# 日志配置
AGENT_LOG_LEVEL=INFO
AGENT_DEBUG=false
